#!/usr/bin/env python3
"""
phoned - Phone Server CLI Client
Control your Android phone server from any machine.
"""
import os
import sys
import json
import subprocess
import argparse
from pathlib import Path

try:
    import requests
except ImportError:
    print("[!] pip install requests")
    sys.exit(1)

# ============================================================
# CONFIG
# ============================================================

CONFIG_DIR = Path.home() / ".phoned"
CONFIG_FILE = CONFIG_DIR / "config.json"

DEFAULT_CONFIG = {
    "ssh_host": "phone",
    "ssh_port": 8022,
    "ssh_user": "",
    "ssh_key": "",
    "api_host": "localhost",
    "api_port": 5000,
    "api_token": "",
    "tunnel_host": "",
}

BANNER = """
\033[35m╔══════════════════════════════════════════════════╗
║         PHONED - Phone Server CLI                ║
╚══════════════════════════════════════════════════╝\033[0m
"""

def load_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                return json.load(f)
        except Exception:
            pass
    return DEFAULT_CONFIG.copy()

def save_config(config):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)

# ============================================================
# API
# ============================================================

def api(endpoint, method="GET", data=None):
    config = load_config()
    base = f"http://{config['api_host']}:{config['api_port']}"
    url = f"{base}{endpoint}"
    headers = {}
    if config.get("api_token"):
        headers["Authorization"] = f"Bearer {config['api_token']}"

    try:
        if method == "GET":
            r = requests.get(url, headers=headers, timeout=10)
        elif method == "POST":
            r = requests.post(url, json=data, headers=headers, timeout=10)
        elif method == "DELETE":
            r = requests.delete(url, headers=headers, timeout=10)
        else:
            r = requests.get(url, headers=headers, timeout=10)

        if r.status_code == 401:
            return {"error": "Auth failed - run: phoned init"}
        return r.json()
    except requests.ConnectionError:
        return {"error": "Cannot connect to phone. Is phoned running? Try: phoned ssh"}
    except Exception as e:
        return {"error": str(e)}

# ============================================================
# SSH
# ============================================================

def ssh_connect(cmd=None):
    config = load_config()
    args = ["ssh", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=10",
            "-p", str(config["ssh_port"])]
    if config.get("ssh_key"):
        args.extend(["-i", config["ssh_key"]])
    args.append(f"{config['ssh_user']}@{config['ssh_host']}")
    if cmd:
        args.append(cmd)
    return subprocess.run(args).returncode

def rsync_deploy(local_path, remote_path):
    config = load_config()
    args = ["rsync", "-avzP", "--delete", "-e",
            f"ssh -p {config['ssh_port']} -o StrictHostKeyChecking=no"]
    if config.get("ssh_key"):
        args[3] += f" -i {config['ssh_key']}"
    args.extend([local_path, f"{config['ssh_user']}@{config['ssh_host']}:{remote_path}"])
    return subprocess.run(args).returncode

# ============================================================
# COMMANDS
# ============================================================

def cmd_init(args):
    print(BANNER)
    config = load_config()

    print("  Setup your phone server connection.\n")

    val = input(f"  SSH username [whoami on phone] [{config.get('ssh_user', '')}]: ").strip()
    if val: config["ssh_user"] = val

    val = input(f"  SSH hostname/IP [{config.get('ssh_host', 'phone')}]: ").strip()
    if val: config["ssh_host"] = val

    val = input(f"  SSH port [{config.get('ssh_port', 8022)}]: ").strip()
    if val: config["ssh_port"] = int(val)

    val = input(f"  SSH key [{config.get('ssh_key', '~/.ssh/phone_key')}]: ").strip()
    if val: config["ssh_key"] = os.path.expanduser(val)

    val = input(f"  API token (from phone setup) [{config.get('api_token', '')}]: ").strip()
    if val: config["api_token"] = val

    val = input(f"  Cloudflare tunnel hostname (blank=none) [{config.get('tunnel_host', '')}]: ").strip()
    if val: config["tunnel_host"] = val

    save_config(config)
    print(f"\n  Config saved: {CONFIG_FILE}")

    # Test SSH
    print("\n  Testing SSH...")
    result = subprocess.run(
        ["ssh", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=5",
         "-p", str(config["ssh_port"]),
         f"{config['ssh_user']}@{config['ssh_host']}", "echo ok"],
        capture_output=True, text=True, timeout=10
    )
    if "ok" in result.stdout:
        print("  \033[32m[+] SSH connection works!\033[0m")
    else:
        print(f"  \033[33m[!] SSH test failed - run: ssh-copy-id or set password\033[0m")

    # Test API
    if config.get("api_token"):
        print("  Testing API...")
        data = api("/health")
        if "status" in data:
            print(f"  \033[32m[+] API works! Status: {data['status']}\033[0m")
        else:
            print(f"  \033[33m[!] API test failed: {data.get('error', 'unknown')}\033[0m")

def cmd_status(args):
    data = api("/status")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    print(f"\n  \033[36m{'PHONE SERVER':^40}\033[0m\n")
    print(f"  Uptime:      {data.get('uptime', 'N/A')}")

    cpu = data.get("cpu", {})
    pct = cpu.get("percent", 0)
    c = "\033[32m" if pct < 70 else "\033[33m" if pct < 90 else "\033[31m"
    print(f"  CPU:         {c}{pct}%\033[0m ({cpu.get('cores', '?')} cores)")
    print(f"  Load:        {' / '.join(str(x) for x in cpu.get('load', [0,0,0]))}")

    mem = data.get("memory", {})
    pct = mem.get("percent", 0)
    c = "\033[32m" if pct < 70 else "\033[33m" if pct < 90 else "\033[31m"
    print(f"  Memory:      {c}{pct}%\033[0m ({mem.get('used_mb', 0)}MB / {mem.get('total_mb', 0)}MB)")

    disk = data.get("disk", {})
    pct = disk.get("percent", 0)
    c = "\033[32m" if pct < 80 else "\033[33m" if pct < 95 else "\033[31m"
    print(f"  Disk:        {c}{pct}%\033[0m ({disk.get('used_gb', 0)}GB / {disk.get('total_gb', 0)}GB)")

    bat = data.get("battery", {})
    bat_pct = bat.get("percentage", -1)
    c = "\033[32m" if bat_pct > 30 else "\033[33m" if bat_pct > 15 else "\033[31m"
    print(f"  Battery:     {c}{bat_pct}%\033[0m ({bat.get('status', 'unknown')})")
    print()

def cmd_ssh(args):
    sys.exit(ssh_connect())

def cmd_run(args):
    result = ssh_connect(args.cmd)
    sys.exit(result)

def cmd_deploy(args):
    local = Path(args.path).resolve()
    if not local.exists():
        print(f"\033[31m[!]\033[0m Not found: {local}")
        return
    if local.is_file():
        print(f"\033[31m[!]\033[0m Deploy directories, not files")
        return

    name = args.name or local.name
    remote = f"~/projects/{name}/"

    print(f"[*] Creating project on phone...")
    api(f"/projects/{name}", method="POST")

    print(f"[*] Syncing...")
    rsync_deploy(str(local) + "/", remote)

    print(f"\033[32m[+]\033[0m Deployed '{name}'")

def cmd_services(args):
    data = api("/services")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    print(f"\n  {'SERVICE':20s} {'STATUS'}")
    print(f"  {'─'*20} {'─'*20}")
    for svc in data.get("services", []):
        status = svc["status"]
        if "run:" in status:
            color = "\033[32m"; icon = "●"
        elif "down:" in status:
            color = "\033[31m"; icon = "○"
        else:
            color = "\033[33m"; icon = "◌"
        print(f"  {icon} {svc['name']:18s} {color}{status}\033[0m")
    print()

def cmd_service(args):
    if args.action == "status":
        data = api(f"/services/{args.name}")
    else:
        data = api(f"/services/{args.name}/{args.action}", method="POST")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
    elif args.action == "status":
        print(f"{args.name}: {data.get('status', 'unknown')}")
    else:
        ok = data.get("ok", False)
        sym = "\033[32m[+]\033[0m" if ok else "\033[31m[!]\033[0m"
        print(f"{sym} {args.name}: {args.action}")

def cmd_projects(args):
    data = api("/projects")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return
    projects = data.get("projects", [])
    if not projects:
        print("  No projects. Deploy: phoned deploy <path>")
        return
    print(f"\n  {'PROJECT':20s} {'STATUS':10s} {'SIZE'}")
    print(f"  {'─'*20} {'─'*10} {'─'*10}")
    for p in projects:
        status = "\033[32mrunning\033[0m" if p.get("running") else "\033[31mstopped\033[0m"
        print(f"  {p['name']:20s} {status:21s} {p.get('size_mb', 0)}MB")
    print()

def cmd_logs(args):
    target = args.service or args.app
    if not target:
        print("Usage: phoned logs <name>")
        return
    data = api(f"/logs/{target}?lines={args.lines}" if not args.app else f"/logs/app/{target}?lines={args.lines}")
    print(data.get("logs", data.get("error", "No logs")))

def cmd_tunnel(args):
    data = api(f"/tunnel/{args.action}", method="POST") if args.action != "status" else api("/tunnel/status")
    print(json.dumps(data, indent=2) if "error" not in data else f"\033[31m[!]\033[0m {data['error']}")

def cmd_anon(args):
    action = args.action
    if action == "status":
        data = api("/tor/status")
        if "error" in data:
            print(f"\033[31m[!]\033[0m {data['error']}"); return
        sym = "\033[32mON\033[0m" if data.get("running") else "\033[31mOFF\033[0m"
        print(f"  Tor:     {sym}")
        print(f"  Tor IP:  {data.get('ip', 'N/A')}")
        for o in data.get("onion_services", []):
            print(f"  Onion:   {o}")
    elif action == "ip":
        data = api("/network")
        print(f"  Tor IP: {data.get('tor_ip', 'N/A')}")
    else:
        data = api(f"/tor/{action}", method="POST")
        if "error" in data:
            print(f"\033[31m[!]\033[0m {data['error']}")
        else:
            print(f"\033[32m[+]\033[0m Tor {action}")

def cmd_network(args):
    data = api("/network")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}"); return
    print(f"\n  Local IP:   {data.get('local_ip', 'N/A')}")
    print(f"  Public IP:  {data.get('public_ip', 'N/A')}")
    print(f"  Tor IP:     {data.get('tor_ip', 'N/A')}")
    print(f"  SSH Port:   {data.get('ssh_port', 8022)}\n")

def cmd_health(args):
    data = api("/maint/health")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}"); return
    healthy = data.get("healthy", False)
    sym = "\033[32mHEALTHY\033[0m" if healthy else "\033[31mDEGRADED\033[0m"
    print(f"\n  Health: {sym}\n")
    for name, check in data.get("checks", {}).items():
        if isinstance(check, dict):
            running = check.get("running", check.get("online_processes", "?"))
            warning = check.get("warning", False)
            w = " \033[33m[WARN]\033[0m" if warning else ""
            print(f"  {name:15s}  {running}{w}")
    print()

def cmd_device(args):
    action = args.action
    if action == "battery":
        print(json.dumps(api("/battery"), indent=2))
    elif action == "notify":
        t = input("Title: ").strip(); m = input("Message: ").strip()
        api("/device/notification", "POST", {"title": t, "message": m})
        print("\033[32m[+]\033[0m Sent")
    elif action == "torch":
        s = input("On/Off: ").strip().lower() == "on"
        api("/device/torch", "POST", s)
    elif action == "location":
        data = api("/device/location")
        if "latitude" in data:
            print(f"  {data['latitude']}, {data['longitude']}")
            print(f"  https://maps.google.com/?q={data['latitude']},{data['longitude']}")
        else: print(json.dumps(data, indent=2))

def cmd_files(args):
    action = args.action
    if action == "list":
        data = api(f"/files/list?path={args.path or '~'}")
        print(data.get("listing", data.get("error", "")))
    elif action == "read":
        if not args.path: print("Usage: phoned files read <path>"); return
        data = api(f"/files/read?path={args.path}")
        print(data.get("content", data.get("error", "")))

def cmd_ports(args):
    """Port forwarding."""
    config = load_config()
    local = args.local_port or args.remote_port
    args_list = ["ssh", "-o", "StrictHostKeyChecking=no", "-N",
                 "-L", f"{local}:localhost:{args.remote_port}",
                 "-p", str(config["ssh_port"])]
    if config.get("ssh_key"):
        args_list.extend(["-i", config["ssh_key"]])
    args_list.append(f"{config['ssh_user']}@{config['ssh_host']}")
    print(f"[*] Forwarding localhost:{local} -> phone:{args.remote_port}")
    print("    Ctrl+C to stop\n")
    try:
        subprocess.run(args_list)
    except KeyboardInterrupt:
        print("\n[+] Stopped")

def cmd_sync(args):
    local = Path(args.path).resolve()
    remote = f"~/projects/{local.name}/"
    print(f"[*] Syncing {local} <-> phone:{remote}")
    rsync_deploy(str(local) + "/", remote)
    print("\033[32m[+]\033[0m Done")

def cmd_update(args):
    print("[*] Updating...")
    data = api("/maint/update", method="POST")
    print(data.get("output", data.get("error", "Done")))

def cmd_reboot(args):
    if input("\033[33m[!] Reboot phone? (yes/no): \033[0m").lower() == "yes":
        api("/maint/reboot", method="POST")
        print("[+] Rebooting...")

def cmd_ssh_restart(args):
    data = api("/maint/ssh-restart", method="POST")
    print(f"\033[32m[+]\033[0m SSH {'restarted' if data.get('ok') else 'failed'}")

# ============================================================
# MAIN
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        prog="phoned",
        description="Phone Server CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("init", help="Setup wizard")
    sub.add_parser("status", help="Phone status")
    sub.add_parser("ssh", help="SSH session")

    p = sub.add_parser("run", help="Run command"); p.add_argument("cmd")
    sub.add_parser("services", help="List services")

    p = sub.add_parser("service", help="Control service")
    p.add_argument("name"); p.add_argument("action", choices=["status","start","stop","restart"])

    sub.add_parser("projects", help="List projects")

    p = sub.add_parser("deploy", help="Deploy project")
    p.add_argument("path"); p.add_argument("--name")

    p = sub.add_parser("logs", help="View logs")
    p.add_argument("service", nargs="?"); p.add_argument("--app"); p.add_argument("--lines", type=int, default=50)

    p = sub.add_parser("tunnel", help="Tunnel"); p.add_argument("action", choices=["status","start","stop"])
    p = sub.add_parser("anon", help="Anonymous"); p.add_argument("action", choices=["status","start","stop","rotate","ip"])

    sub.add_parser("network", help="Network info")
    sub.add_parser("health", help="Health check")

    p = sub.add_parser("device", help="Device"); p.add_argument("action", choices=["battery","notify","torch","location"])

    p = sub.add_parser("files", help="Files")
    p.add_argument("action", choices=["list","read"]); p.add_argument("path", nargs="?")

    p = sub.add_parser("ports", help="Port forward"); p.add_argument("remote_port", type=int); p.add_argument("local_port", nargs="?", type=int)
    p = sub.add_parser("sync", help="Sync dir"); p.add_argument("path")

    sub.add_parser("update", help="Update packages")
    sub.add_parser("reboot", help="Reboot phone")
    sub.add_parser("ssh-restart", help="Restart SSH")

    args = parser.parse_args()

    if not args.command:
        print(BANNER)
        parser.print_help()
        return

    cmds = {
        "init": cmd_init, "status": cmd_status, "ssh": cmd_ssh,
        "run": cmd_run, "services": cmd_services, "service": cmd_service,
        "projects": cmd_projects, "deploy": cmd_deploy, "logs": cmd_logs,
        "tunnel": cmd_tunnel, "anon": cmd_anon, "network": cmd_network,
        "health": cmd_health, "device": cmd_device, "files": cmd_files,
        "ports": cmd_ports, "sync": cmd_sync, "update": cmd_update,
        "reboot": cmd_reboot, "ssh-restart": cmd_ssh_restart,
    }
    func = cmds.get(args.command)
    if func:
        func(args)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
