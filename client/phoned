def cmd_health(args):
    """Health check."""
    data = api("/maint/health")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    healthy = data.get("healthy", False)
    sym = "\033[32mHEALTHY\033[0m" if healthy else "\033[31mDEGRADED\033[0m"
    print(f"\n  Health: {sym}\n")

    for name, check in data.get("checks", {}).items():
        if isinstance(check, dict):
            running = check.get("running", check.get("online_processes", "?"))
            warning = check.get("warning", False)
            if warning:
                warn_sym = " \033[33m[WARN]\033[0m"
            elif running is True or (isinstance(running, str) and running):
                warn_sym = " \033[32m[OK]\033[0m"
            else:
                warn_sym = " \033[31m[FAIL]\033[0m"
            print(f"  {name:15s}  {running}{warn_sym}")
    print()


def cmd_device(args):
    """Device control."""
    action = args.action
    if action == "battery":
        data = api("/battery")
        print_json(data)
    elif action == "notify":
        title = input("Title: ").strip()
        msg = input("Message: ").strip()
        api("/device/notification", "POST", {"title": title, "message": msg})
        print("\033[32m[+]\033[0m Notification sent")
    elif action == "vibrate":
        api("/device/vibrate", "POST", 200)
        print("\033[32m[+]\033[0m Vibrated")
    elif action == "torch":
        state = input("Torch on/off: ").strip().lower() == "on"
        api("/device/torch", "POST", state)
        print(f"\033[32m[+]\033[0m Torch {'on' if state else 'off'}")
    elif action == "location":
        data = api("/device/location")
        if "latitude" in data:
            print(f"  Lat: {data['latitude']}, Lon: {data['longitude']}")
            print(f"  Maps: https://maps.google.com/?q={data['latitude']},{data['longitude']}")
        else:
            print_json(data)
    elif action == "clipboard":
        data = api("/device/clipboard")
        print(f"  Clipboard: {data.get('content', 'empty')}")


def cmd_files(args):
    """File management."""
    action = args.action
    if action == "list":
        path = args.path or "~"
        data = api(f"/files/list?path={path}")
        if "listing" in data:
            print(data["listing"])
    elif action == "read":
        if not args.path:
            print("Usage: phoned files read <path>")
            return
        data = api(f"/files/read?path={args.path}")
        if "content" in data:
            print(data["content"])
        else:
            print(f"\033[31m[!]\033[0m {data.get('error', 'Not found')}")
    elif action == "download":
        if not args.path:
            print("Usage: phoned files download <remote-path> [local-path]")
            return
        local = args.local or Path(args.path).name
        scp_cmd(str(local), args.path, upload=False)
        print(f"\033[32m[+]\033[0m Downloaded to {local}")
    elif action == "upload":
        if not args.path:
            print("Usage: phoned files upload <local-path> [remote-path]")
            return
        remote = args.remote or f"~/"
        scp_cmd(args.path, remote, upload=True)
        print(f"\033[32m[+]\033[0m Uploaded to phone:{remote}")


def cmd_update(args):
    """Update packages."""
    print("[*] Updating phone packages...")
    data = api("/maint/update", method="POST")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
    else:
        print(data.get("output", "Update complete"))


def cmd_reboot(args):
    """Reboot phone."""
    confirm = input("\033[33m[!] Reboot phone? (yes/no): \033[0m")
    if confirm.lower() == "yes":
        api("/maint/reboot", method="POST")
        print("[+] Rebooting...")


def cmd_ports(args):
    """Port forwarding - expose phone ports locally."""
    config = load_config()
    host = config["ssh_host"]
    port = config["ssh_port"]
    user = config["ssh_user"]
    key = config.get("ssh_key", "")

    remote_port = args.remote_port
    local_port = args.local_port or remote_port

    ssh_args = ["ssh", "-o", "StrictHostKeyChecking=no",
                "-N", "-L", f"{local_port}:localhost:{remote_port}",
                "-p", str(port)]
    if key:
        ssh_args.extend(["-i", key])
    ssh_args.append(f"{user}@{host}")

    print(f"[*] Forwarding localhost:{local_port} -> phone:{remote_port}")
    print("    Press Ctrl+C to stop\n")

    try:
        subprocess.run(ssh_args)
    except KeyboardInterrupt:
        print("\n[+] Port forward stopped")


def cmd_sync(args):
    """Sync a directory bidirectionally."""
    local = Path(args.path).resolve()
    remote = f"~/projects/{local.name}/"

    if args.push:
        print(f"[*] Pushing {local} -> phone:{remote}")
        rsync_cmd(str(local) + "/", remote)
    elif args.pull:
        print(f"[*] Pulling phone:{remote} -> {local}")
        local.mkdir(parents=True, exist_ok=True)
        rsync_cmd(str(local) + "/", remote, upload=False)
    else:
        # Smart sync: push local changes
        print(f"[*] Syncing {local} <-> phone:{remote}")
        rsync_cmd(str(local) + "/", remote)

    print("\033[32m[+]\033[0m Sync complete")


def cmd_exec(args):
    """Execute a script file on the phone."""
    script = args.script
    if not os.path.exists(script):
        # Try as a command string
        result = ssh_cmd(script)
        print(result)
        return

    with open(script) as f:
        content = f.read()

    # Upload and execute
    tmp = f"/tmp/phoned_exec_{os.getpid()}.sh"
    ssh_cmd(f"echo '{content}' > {tmp} && chmod +x {tmp} && bash {tmp} && rm {tmp}")


