def cmd_init(args):
    """Interactive setup wizard."""
    print(BANNER)
    print("  Let's configure your phone server connection.\n")

    config = load_config()

    val = input(f"  SSH username [whoami on phone] [{config.get('ssh_user', '')}]: ").strip()
    if val:
        config["ssh_user"] = val

    val = input(f"  SSH key path [{config.get('ssh_key', '~/.ssh/phone_key')}]: ").strip()
    if val:
        config["ssh_key"] = os.path.expanduser(val)

    val = input(f"  SSH hostname/IP [{config.get('ssh_host', 'phone')}]: ").strip()
    if val:
        config["ssh_host"] = val

    val = input(f"  SSH port [{config.get('ssh_port', 8022)}]: ").strip()
    if val:
        config["ssh_port"] = int(val)

    val = input(f"  Cloudflare tunnel hostname (blank=none) [{config.get('tunnel_host', '')}]: ").strip()
    if val:
        config["tunnel_host"] = val

    # Test connection
    print("\n  Testing SSH connection...")
    save_config(config)
    result = ssh_cmd("echo 'connected'")
    if "connected" in str(result):
        print("  \033[32m[+] Connection successful!\033[0m")
    else:
        print(f"  \033[33m[!] Could not connect: {result}\033[0m")
        print("  Make sure SSH keys are set up. Run:")
        print("    bash scripts/setup-ssh-keys.sh")

    print(f"\n  Config saved: {CONFIG_FILE}")


def cmd_status(args):
    """Show phone server status."""
    data = api("/status")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    print(f"\n  \033[36m{'PHONE SERVER STATUS':^40}\033[0m\n")
    print(f"  Uptime:      {data.get('uptime', 'N/A')}")

    cpu = data.get("cpu", {})
    pct = cpu.get("percent", 0)
    color = "\033[32m" if pct < 70 else "\033[33m" if pct < 90 else "\033[31m"
    print(f"  CPU:         {color}{pct}%\033[0m ({cpu.get('cores', '?')} cores)")
    load = cpu.get("load", {})
    print(f"  Load:        {load.get('1m', 0)} / {load.get('5m', 0)} / {load.get('15m', 0)}")

    mem = data.get("memory", {})
    pct = mem.get("percent", 0)
    color = "\033[32m" if pct < 70 else "\033[33m" if pct < 90 else "\033[31m"
    print(f"  Memory:      {color}{pct}%\033[0m ({mem.get('used_mb', 0)}MB / {mem.get('total_mb', 0)}MB)")

    disk = data.get("disk", {})
    pct = disk.get("percent", 0)
    color = "\033[32m" if pct < 80 else "\033[33m" if pct < 95 else "\033[31m"
    print(f"  Disk:        {color}{pct}%\033[0m ({disk.get('used_gb', 0)}GB / {disk.get('total_gb', 0)}GB)")

    bat = data.get("battery", {})
    bat_pct = bat.get("percentage", -1)
    color = "\033[32m" if bat_pct > 30 else "\033[33m" if bat_pct > 15 else "\033[31m"
    print(f"  Battery:     {color}{bat_pct}%\033[0m ({bat.get('status', 'unknown')})")
    print(f"  Temperature: {bat.get('temperature', 'N/A')}°C")
    print()


def cmd_ssh(args):
    """Open SSH session (interactive)."""
    config = load_config()
    host = config["ssh_host"]
    port = config["ssh_port"]
    user = config["ssh_user"]
    key = config.get("ssh_key", "")

    ssh_args = ["ssh", "-o", "StrictHostKeyChecking=no", "-p", str(port)]
    if key:
        ssh_args.extend(["-i", key])
    ssh_args.append(f"{user}@{host}")

    sys.exit(subprocess.run(ssh_args).returncode)


def cmd_run(args):
    """Execute command on phone."""
    result = ssh_cmd(args.cmd)
    print(result)


def cmd_deploy(args):
    """Deploy a project to the phone."""
    local_path = Path(args.path).resolve()
    if not local_path.exists():
        print(f"\033[31m[!]\033[0m Not found: {local_path}")
        return

    name = args.name or local_path.name
    remote = f"~/projects/{name}/"

    print(f"[*] Creating project on phone...")
    api(f"/projects/{name}", method="POST")

    if local_path.is_dir():
        print(f"[*] Syncing {local_path} -> phone:{remote}")
        rsync_cmd(str(local_path) + "/", remote)
    else:
        print(f"[*] Uploading {local_path.name} -> phone:{remote}")
        scp_cmd(str(local_path), remote)

    print(f"\033[32m[+]\033[0m Deployed '{name}'")
    print(f"    Run on phone: cd ~/projects/{name} && pm2 start run.sh --name {name}")


def cmd_services(args):
    """List services."""
    data = api("/services")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    print(f"\n  {'SERVICE':20s} {'STATUS'}")
    print(f"  {'─'*20} {'─'*20}")
    for svc in data.get("services", []):
        status = svc["status"]
        if "run:" in status:
            color = "\033[32m"
            icon = "●"
        elif "down:" in status:
            color = "\033[31m"
            icon = "○"
        else:
            color = "\033[33m"
            icon = "◌"
        print(f"  {icon} {svc['name']:18s} {color}{status}\033[0m")
    print()


def cmd_service(args):
    """Control a service."""
    action = args.action
    name = args.name

    if action == "status":
        data = api(f"/services/{name}")
    else:
        data = api(f"/services/{name}/{action}", method="POST")

    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
    elif action == "status":
        print(f"{name}: {data.get('status', 'unknown')}")
    else:
        ok = data.get("ok", False)
        sym = "\033[32m[+]\033[0m" if ok else "\033[31m[!]\033[0m"
        print(f"{sym} {name}: {action}")


def cmd_projects(args):
    """List projects."""
    data = api("/projects")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    projects = data.get("projects", [])
    if not projects:
        print("  No projects. Deploy with: phoned deploy <path>")
        return

    print(f"\n  {'PROJECT':20s} {'STATUS':10s} {'SIZE':10s}")
    print(f"  {'─'*20} {'─'*10} {'─'*10}")
    for proj in projects:
        status = "\033[32mrunning\033[0m" if proj.get("running") else "\033[31mstopped\033[0m"
        size = f"{proj.get('size_mb', 0)}MB"
        print(f"  {proj['name']:20s} {status:22s} {size}")
    print()


