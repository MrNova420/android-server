        print_json(data)


def cmd_anon(args):
    """Anonymous mode."""
    action = args.action
    if action == "status":
        data = api("/tor/status")
        if "error" in data:
            print(f"\033[31m[!]\033[0m {data['error']}")
            return
        running = data.get("running", False)
        sym = "\033[32mON\033[0m" if running else "\033[31mOFF\033[0m"
        print(f"  Tor:     {sym}")
        print(f"  Tor IP:  {data.get('ip', 'N/A')}")
        for onion in data.get("onion_services", []):
            print(f"  Onion:   {onion}")
    elif action == "ip":
        data = api("/network")
        print(f"  Tor IP: {data.get('tor_ip', 'N/A')}")
    else:
        data = api(f"/tor/{action}", method="POST")
        if "error" in data:
            print(f"\033[31m[!]\033[0m {data['error']}")
        else:
            print(f"\033[32m[+]\033[0m Tor {action}")


def cmd_network(args):
    """Network info."""
    data = api("/network")
    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
        return

    print(f"\n  {'NETWORK INFO':^40}\n")
    print(f"  Local IP:   {data.get('local_ip', 'N/A')}")
    print(f"  Public IP:  {data.get('public_ip', 'N/A')}")
    print(f"  Tor IP:     {data.get('tor_ip', 'N/A')}")
    print(f"  SSH Port:   {data.get('ssh_port', 8022)}")
