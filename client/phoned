def main():
    parser = argparse.ArgumentParser(
        prog="phoned",
        description="Phone Server CLI - Full remote control of your Android VPS",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  phoned init                     Setup connection
  phoned status                   Phone status
  phoned ssh                      SSH session
  phoned run "ls -la"             Remote command
  phoned deploy ./myapp           Deploy project
  phoned services                 List services
  phoned service sshd restart     Restart service
  phoned projects                 List projects
  phoned logs sshd                View logs
  phoned anon on                  Enable Tor
  phoned anon rotate              New Tor IP
  phoned ports 8080               Forward port 8080 locally
  phoned sync ./myapp             Sync directory
  phoned health                   Health check
  phoned device battery           Battery info
        """
    )

    sub = parser.add_subparsers(dest="command")

    sub.add_parser("init", help="Setup wizard")
    sub.add_parser("status", help="Phone status")
    sub.add_parser("ssh", help="SSH session")

    p = sub.add_parser("run", help="Run remote command")
    p.add_argument("cmd", help="Command")

    sub.add_parser("services", help="List services")

    p = sub.add_parser("service", help="Control service")
    p.add_argument("name")
    p.add_argument("action", choices=["status", "start", "stop", "restart"])

    sub.add_parser("projects", help="List projects")

    p = sub.add_parser("deploy", help="Deploy project")
    p.add_argument("path", help="Local path")
    p.add_argument("--name", help="Project name")

    p = sub.add_parser("logs", help="View logs")
    p.add_argument("service", nargs="?")
    p.add_argument("--app", help="App logs")
    p.add_argument("--lines", type=int, default=50)

    p = sub.add_parser("tunnel", help="Tunnel management")
    p.add_argument("action", choices=["status", "start", "stop"])

    p = sub.add_parser("anon", help="Anonymous mode")
    p.add_argument("action", choices=["status", "start", "stop", "rotate", "ip"])

    sub.add_parser("network", help="Network info")
    sub.add_parser("health", help="Health check")

    p = sub.add_parser("device", help="Device control")
    p.add_argument("action", choices=["battery", "notify", "vibrate", "torch", "location", "clipboard"])

    p = sub.add_parser("files", help="File management")
    p.add_argument("action", choices=["list", "read", "download", "upload"])
    p.add_argument("path", nargs="?")
    p.add_argument("--local", help="Local path for download")
    p.add_argument("--remote", help="Remote path for upload")

    sub.add_parser("update", help="Update packages")
    sub.add_parser("reboot", help="Reboot phone")

    p = sub.add_parser("ports", help="Port forwarding")
    p.add_argument("remote_port", type=int, help="Phone port")
    p.add_argument("local_port", nargs="?", type=int, help="Local port")

    p = sub.add_parser("sync", help="Sync directory")
    p.add_argument("path", help="Local directory")
    p.add_argument("--push", action="store_true")
    p.add_argument("--pull", action="store_true")

    p = sub.add_parser("exec", help="Execute script on phone")
    p.add_argument("script", help="Script file or command string")

    args = parser.parse_args()

    if not args.command:
        print(BANNER)
        parser.print_help()
        return

