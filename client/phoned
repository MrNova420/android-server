        print("Usage: phoned logs <service-or-app>")
        return

    if args.app:
        data = api(f"/logs/app/{target}?lines={args.lines}")
    else:
        data = api(f"/logs/{target}?lines={args.lines}")

    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
    else:
        print(data.get("logs", "No logs"))


def cmd_tunnel(args):
    """Manage tunnel."""
    action = args.action
    if action == "status":
        data = api("/tunnel/status")
    else:
        data = api(f"/tunnel/{action}", method="POST")

    if "error" in data:
        print(f"\033[31m[!]\033[0m {data['error']}")
