CONFIG_DIR = Path.home() / ".phoned"
CONFIG_FILE = CONFIG_DIR / "config.json"
DEFAULT_CONFIG = {
    "ssh_host": "phone",
    "ssh_port": 8022,
    "ssh_user": "",
    "ssh_key": "",
    "api_host": "localhost",
    "api_port": 5000,
    "tunnel_host": "",
    "tunnel_port": 22,
}

BANNER = """
\033[35m╔══════════════════════════════════════════════════╗
║         PHONED - Phone Server CLI                ║
║       Your Android VPS, anywhere                 ║
╚══════════════════════════════════════════════════╝\033[0m
"""


def load_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if CONFIG_FILE.exists():
        with open(CONFIG_FILE) as f:
            return json.load(f)
    return DEFAULT_CONFIG


def save_config(config):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)


def api(endpoint, method="GET", data=None):
    """Call the phoned API via SSH tunnel or direct."""
    config = load_config()
    # Build URL
    base = f"http://{config['api_host']}:{config['api_port']}"
    url = f"{base}{endpoint}"

    try:
        if method == "GET":
            r = requests.get(url, timeout=15)
        elif method == "POST":
            r = requests.post(url, json=data, timeout=15)
        elif method == "DELETE":
            r = requests.delete(url, timeout=15)
        else:
            r = requests.get(url, timeout=15)
        return r.json()
    except requests.ConnectionError:
        # Fallback: try via SSH
        return api_via_ssh(endpoint, method, data)
    except Exception as e:
        return {"error": str(e)}


def api_via_ssh(endpoint, method="GET", data=None):
    """Fallback API call via SSH if direct connection fails."""
    config = load_config()
    cmd_parts = ["curl", "-s"]

    if method == "POST" and data:
        cmd_parts.extend(["-X", "POST", "-H", "'Content-Type: application/json'",
                          "-d", f"'{json.dumps(data)}'"])
    elif method == "DELETE":
        cmd_parts.append("-X DELETE")

    cmd_parts.append(f"'http://localhost:{config['api_port']}{endpoint}'")

    result = ssh_cmd(" ".join(cmd_parts))
    try:
        return json.loads(result) if isinstance(result, str) else result
    except Exception:
        return {"output": result}


def ssh_cmd(cmd=None, interactive=False):
    """Execute SSH command or open interactive session."""
    config = load_config()
    host = config["ssh_host"]
    port = config["ssh_port"]
    user = config["ssh_user"]
    key = config.get("ssh_key", "")

    ssh_args = ["ssh", "-o", "StrictHostKeyChecking=no",
                "-o", "ConnectTimeout=10",
                "-p", str(port)]
    if key:
        ssh_args.extend(["-i", key])

    ssh_args.append(f"{user}@{host}")

    if interactive:
        return subprocess.run(ssh_args).returncode
    elif cmd:
        ssh_args.append(cmd)
        result = subprocess.run(ssh_args, capture_output=True, text=True, timeout=60)
        if result.returncode != 0 and result.stderr:
            return result.stderr.strip()
        return result.stdout.strip()
    return ""


def scp_cmd(local_path, remote_path, upload=True):
    """SCP file to/from phone."""
    config = load_config()
    host = config["ssh_host"]
    port = config["ssh_port"]
    user = config["ssh_user"]
    key = config.get("ssh_key", "")

    args = ["scp", "-P", str(port), "-o", "StrictHostKeyChecking=no"]
    if key:
        args.extend(["-i", key])

    if upload:
        args.extend([local_path, f"{user}@{host}:{remote_path}"])
    else:
        args.extend([f"{user}@{host}:{remote_path}", local_path])

    return subprocess.run(args).returncode


def rsync_cmd(local_path, remote_path, upload=True):
    """Rsync directory to/from phone."""
    config = load_config()
    host = config["ssh_host"]
    port = config["ssh_port"]
    user = config["ssh_user"]
    key = config.get("ssh_key", "")

    remote = f"{user}@{host}:{remote_path}"
    args = ["rsync", "-avzP", "--delete", "-e", f"ssh -p {port} -o StrictHostKeyChecking=no"]
    if key:
        args[4] += f" -i {key}"

    if upload:
        args.extend([local_path, remote])
    else:
        args.extend([remote, local_path])

    return subprocess.run(args).returncode


def print_json(data, indent=2):
    """Pretty print JSON with colors."""
    if isinstance(data, dict):
        for k, v in data.items():
            if isinstance(v, bool):
                color = "\033[32m" if v else "\033[31m"
                sym = "yes" if v else "no"
                print(f"  {k:20s} {color}{sym}\033[0m")
            elif isinstance(v, dict):
                print(f"\n  \033[36m{k}:\033[0m")
                for sk, sv in v.items():
                    print(f"    {sk:18s} {sv}")
            else:
                print(f"  {k:20s} {v}")
    else:
        print(json.dumps(data, indent=indent))


